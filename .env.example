# ── Toxik Configuration ─────────────────────────────────────────────────────
# Copy this file to .env and edit to override defaults.
# All variables use the TOXIK_ prefix.

# ── Server ──────────────────────────────────────────────────────────────────
TOXIK_HOST=0.0.0.0
TOXIK_PORT=8000
TOXIK_DATA_DIR=./data
TOXIK_DB_PATH=
TOXIK_THUMB_DIR=
TOXIK_CATALOG=

# ── ComfyUI ─────────────────────────────────────────────────────────────────
TOXIK_COMFYUI_HOST=localhost
TOXIK_COMFYUI_PORT=9988
TOXIK_COMFYUI_WORKFLOW_DIR=
TOXIK_COMFYUI_OUTPUT_DIR=
